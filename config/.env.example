# Otomoto Parser – Environment Configuration

# Database path (relative to project root)
DB_PATH=data/otomoto.db

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Delay between HTTP requests (milliseconds)
REQUEST_DELAY_MS=1500

# Randomized request jitter ratio, e.g. 0.3 = up to +30%
REQUEST_JITTER_RATIO=0.3

# Base HTTP timeout in seconds
HTTP_TIMEOUT_S=20.0

# User-Agent header (leave blank to use built-in rotation)
USER_AGENT=

# Max pages to scrape per search (overrides per-search setting when set)
MAX_PAGES=

# Retry configuration
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_S=2.0

# Export output directory
EXPORT_DIR=exports

# Browser mode
USE_BROWSER=false
BROWSER_FALLBACK_ON_BLOCK=true
BROWSER_TYPE=chromium
